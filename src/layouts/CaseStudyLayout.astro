---
import BaseLayout from './BaseLayout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { SITE } from '../consts';

interface Props {
  client: string;
  title: string;
  summary?: string;
  result: string;
  url?: string;
  image?: ImageMetadata;
  imageAlt?: string;
  tags?: string[];
  publishDate?: Date;
}

const { client, title, summary, result, url = '#', image, imageAlt, tags = [], publishDate } =
  Astro.props;
const hasLive = url !== '#';
const year = publishDate ? publishDate.getFullYear() : undefined;
---

<BaseLayout
  title={`${client} — ${title} · ${SITE.shortName}`}
  description={summary ?? title}
  ogTitle={`${client} · ${SITE.shortName}`}
  ogDescription={summary ?? title}
  ogImage={image?.src}
>
  <article class="cs">
    <div class="wrap cs-head">
      <a class="back" href="/#work">← Selected work</a>
      <span class="eyebrow"><span class="bar"></span>{client}</span>
      <h1 class="h1">{title}</h1>
      {summary && <p class="lead">{summary}</p>}
      <div class="cs-meta">
        {tags.map((t) => <span class="chip">{t}</span>)}
        {year && <span class="cs-year">{year}</span>}
      </div>
    </div>

    <div class="wrap">
      <div class="shot">
        <div class="shot-chrome">
          <i></i><i></i><i></i><span class="url">{result}</span>
        </div>
        <span class="shot-name">{client}</span>
        {
          image && (
            <Image
              class="shot-img"
              src={image}
              alt={imageAlt ?? `${client} website`}
              widths={[640, 1024, 1440]}
              sizes="(min-width: 1180px) 1180px, 100vw"
              loading="eager"
              fetchpriority="high"
            />
          )
        }
      </div>
    </div>

    <div class="wrap prose">
      <slot />
    </div>

    <div class="wrap cs-cta">
      {
        hasLive && (
          <a class="btn btn-ink" href={url} target="_blank" rel="noopener">
            Visit {result} ↗
          </a>
        )
      }
      <a class="btn btn-primary" href="/#contact">Start a project</a>
      <a class="btn btn-ghost" href="/#work">See more work</a>
    </div>
  </article>
</BaseLayout>

<style>
  .cs {
    padding-top: clamp(118px, 15vw, 168px);
    padding-bottom: clamp(48px, 8vw, 96px);
  }
  .cs-head {
    max-width: 820px;
  }
  .back {
    display: inline-block;
    font-size: 14px;
    font-weight: 600;
    color: var(--muted);
    text-decoration: none;
    margin-bottom: 24px;
  }
  .back:hover {
    color: var(--accent-cta);
  }
  .cs-head .eyebrow {
    margin-bottom: 14px;
  }
  .cs-head .h1 {
    font-size: clamp(2.2rem, 5vw, 3.8rem);
  }
  .cs-head .lead {
    margin-top: 18px;
    max-width: 60ch;
  }
  .cs-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    margin-top: 22px;
  }
  .cs-year {
    font-family: var(--sans);
    font-size: 12px;
    color: var(--faint);
    margin-left: 4px;
  }
  /* Hero shot — mirrors the work card visual for continuity. */
  .shot {
    position: relative;
    aspect-ratio: 21/9;
    margin-top: clamp(28px, 5vw, 52px);
    border-radius: var(--r-lg);
    overflow: hidden;
    background: linear-gradient(135deg, oklch(0.29 0.05 288), oklch(0.26 0.055 290));
    border: 1px solid var(--ink-line);
  }
  .shot::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(120% 80% at 80% -10%, oklch(0.72 0.06 272 / 0.28), transparent 55%);
  }
  .shot-chrome {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 40px;
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 0 16px;
    background: oklch(0.24 0.055 288 / 0.55);
    border-bottom: 1px solid var(--ink-line);
    z-index: 2;
  }
  .shot-chrome i {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--ink-line);
  }
  .shot-chrome .url {
    margin-left: 8px;
    font-family: var(--sans);
    font-size: 12px;
    color: var(--on-ink-faint);
  }
  .shot-name {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--serif);
    font-weight: 800;
    font-size: clamp(34px, 6vw, 72px);
    color: oklch(1 0 0 / 0.9);
    z-index: 0;
    letter-spacing: -0.01em;
  }
  .shot-img {
    position: absolute;
    top: 40px; /* sits below the browser chrome bar */
    left: 0;
    right: 0;
    bottom: 0;
    width: auto; /* override width/height attrs from <Image>; insets govern */
    height: auto;
    object-fit: cover;
    object-position: top center; /* top aligned */
    z-index: 1;
  }
  .prose {
    max-width: 720px;
    margin-top: clamp(32px, 5vw, 56px);
  }
  .prose :global(h2) {
    font-family: var(--serif);
    font-weight: 800;
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    letter-spacing: -0.01em;
    margin: 2em 0 0.5em;
  }
  .prose :global(h3) {
    font-family: var(--serif);
    font-weight: 700;
    font-size: 1.35rem;
    margin: 1.6em 0 0.5em;
  }
  .prose :global(p) {
    font-size: 18px;
    line-height: 1.7;
    color: var(--text);
    margin: 0 0 1.2em;
  }
  .prose :global(strong) {
    color: var(--ink);
    font-weight: 700;
  }
  .prose :global(a) {
    color: var(--accent-cta);
    text-underline-offset: 3px;
  }
  .prose :global(ul),
  .prose :global(ol) {
    font-size: 18px;
    line-height: 1.7;
    color: var(--text);
    padding-left: 1.2em;
    margin: 0 0 1.2em;
  }
  .prose :global(blockquote) {
    margin: 1.6em 0;
    padding: 4px 0 4px 22px;
    border-left: 3px solid var(--brand-2);
    font-family: var(--serif);
    font-weight: 600;
    font-size: 1.3rem;
    line-height: 1.3;
    color: var(--ink);
  }
  .cs-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 13px;
    max-width: 720px;
    margin-top: clamp(40px, 6vw, 64px);
    padding-top: clamp(28px, 4vw, 40px);
    border-top: 1px solid var(--line);
  }
</style>
