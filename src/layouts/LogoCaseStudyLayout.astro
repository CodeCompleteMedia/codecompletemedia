---
import BaseLayout from './BaseLayout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import LogoPlate from '../components/work/LogoPlate.astro';
import { SITE } from '../consts';

interface PaletteColor {
  name: string;
  value: string;
}
interface LogoSet {
  primary: ImageMetadata;
  reversed?: ImageMetadata;
  monochrome?: ImageMetadata;
  appIcon?: ImageMetadata;
}
interface Props {
  client: string;
  title: string;
  summary?: string;
  result: string;
  url?: string;
  mark?: string;
  logo?: LogoSet;
  palette?: PaletteColor[];
  tags?: string[];
  publishDate?: Date;
}

const {
  client,
  title,
  summary,
  result,
  url = '#',
  mark,
  logo,
  palette = [],
  tags = [],
  publishDate,
} = Astro.props;
const hasLive = url !== '#';
const year = publishDate ? publishDate.getFullYear() : undefined;

// Specimen tiles — the range a real identity ships with. Only the treatments
// that have art supplied are shown.
const specimens = [
  { key: 'primary', label: 'Primary', img: logo?.primary },
  { key: 'reversed', label: 'Reversed', img: logo?.reversed },
  { key: 'mono', label: 'Monochrome', img: logo?.monochrome },
  { key: 'icon', label: 'App icon', img: logo?.appIcon },
].filter((s) => s.img) as { key: string; label: string; img: ImageMetadata }[];
---

<BaseLayout
  title={`${client} — ${title} · ${SITE.shortName}`}
  description={summary ?? title}
  ogTitle={`${client} · ${SITE.shortName}`}
  ogDescription={summary ?? title}
>
  <article class="cs">
    <div class="wrap cs-head">
      <a class="back" href="/#work">← Selected work</a>
      <span class="eyebrow"><span class="bar"></span>{client} · Identity</span>
      <h1 class="h1">{title}</h1>
      {summary && <p class="lead">{summary}</p>}
      <div class="cs-meta">
        {tags.map((t) => <span class="chip">{t}</span>)}
        {year && <span class="cs-year">{year}</span>}
      </div>
    </div>

    <div class="wrap">
      <div class="hero-plate">
        <LogoPlate
          client={client}
          mark={mark}
          primary={logo?.primary}
          reversed={logo?.reversed}
          palette={palette}
          variant="hero"
        />
      </div>
    </div>

    <div class="wrap">
      <div class="sheet">
        <span class="sheet-label">The mark, end to end</span>
        <div class="specimens">
          {
            specimens.map((s) => (
              <figure class={`spec spec-${s.key}`}>
                <div class="spec-stage">
                  <Image
                    class="spec-img"
                    src={s.img}
                    alt={`${client} logo, ${s.label.toLowerCase()}`}
                    widths={[220, 360]}
                    sizes="220px"
                  />
                </div>
                <figcaption>{s.label}</figcaption>
              </figure>
            ))
          }
        </div>
      </div>
    </div>

    {
      palette.length > 0 && (
        <div class="wrap">
          <div class="sheet">
            <span class="sheet-label">Palette</span>
            <div class="swatches">
              {palette.map((c) => (
                <div class="swatch">
                  <span class="chip-color" style={`--c:${c.value}`} />
                  <div class="swatch-meta">
                    <span class="swatch-name">{c.name}</span>
                    <span class="swatch-value">{c.value}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      )
    }

    <div class="wrap prose">
      <slot />
    </div>

    <div class="wrap cs-cta">
      {
        hasLive && (
          <a class="btn btn-ink" href={url} target="_blank" rel="noopener">
            Visit {result} ↗
          </a>
        )
      }
      <a class="btn btn-primary" href="/#contact">Start a project</a>
      <a class="btn btn-ghost" href="/#work">See more work</a>
    </div>
  </article>
</BaseLayout>

<style>
  .cs {
    padding-top: clamp(118px, 15vw, 168px);
    padding-bottom: clamp(48px, 8vw, 96px);
  }
  .cs-head {
    max-width: 820px;
  }
  .back {
    display: inline-block;
    font-size: 14px;
    font-weight: 600;
    color: var(--muted);
    text-decoration: none;
    margin-bottom: 24px;
  }
  .back:hover {
    color: var(--accent-cta);
  }
  .cs-head .eyebrow {
    margin-bottom: 14px;
  }
  .cs-head .h1 {
    font-size: clamp(2.2rem, 5vw, 3.8rem);
  }
  .cs-head .lead {
    margin-top: 18px;
    max-width: 60ch;
  }
  .cs-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    margin-top: 22px;
  }
  .cs-year {
    font-family: var(--sans);
    font-size: 12px;
    color: var(--faint);
    margin-left: 4px;
  }

  /* Hero brand plate — the logo analogue of the web hero screenshot. */
  .hero-plate {
    position: relative;
    aspect-ratio: 21/9;
    margin-top: clamp(28px, 5vw, 52px);
    border-radius: var(--r-lg);
    overflow: hidden;
    border: 1px solid var(--line);
    box-shadow: var(--shadow-md);
  }

  .sheet {
    margin-top: clamp(40px, 6vw, 72px);
  }
  .sheet-label {
    display: block;
    font-family: var(--sans);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--faint);
    margin-bottom: 16px;
  }

  /* Specimen grid: the mark across the surfaces a brand actually lives on. */
  .specimens {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }
  .spec {
    margin: 0;
  }
  .spec-stage {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1;
    border-radius: var(--r-md);
    border: 1px solid var(--line);
    overflow: hidden;
  }
  .spec-img {
    width: auto;
    height: 58%;
    object-fit: contain;
  }
  /* Transparent lockups (primary, monochrome) sit on a light stage. */
  .spec-primary .spec-stage {
    background: linear-gradient(150deg, oklch(0.975 0.006 286), oklch(0.93 0.011 286));
  }
  .spec-mono .spec-stage {
    background: var(--surface-2);
  }
  /* Reversed is a transparent white lockup, shown on a dark stage to stand for
     its on-dark use. The app icon is a self-contained tile. */
  .spec-reversed .spec-stage {
    background: radial-gradient(130% 100% at 50% 0%, oklch(0.22 0.012 286), oklch(0.16 0.01 286));
    border-color: var(--ink-line);
  }
  .spec-icon .spec-stage {
    background: var(--surface-2);
  }
  .spec-icon .spec-img {
    height: 64%;
    filter: drop-shadow(0 10px 20px oklch(0.24 0.06 288 / 0.28));
  }
  .spec figcaption {
    margin-top: 10px;
    font-family: var(--sans);
    font-size: 12.5px;
    color: var(--muted);
    text-align: center;
  }

  /* Palette swatches with their values. */
  .swatches {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
    gap: 12px;
  }
  .swatch {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    border: 1px solid var(--line);
    border-radius: var(--r-md);
    background: var(--surface);
  }
  .chip-color {
    flex: none;
    width: 40px;
    height: 40px;
    border-radius: var(--r-sm);
    background: var(--c);
    box-shadow: 0 0 0 1px oklch(0.24 0.055 288 / 0.1) inset;
  }
  .swatch-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .swatch-name {
    font-family: var(--sans);
    font-weight: 600;
    font-size: 14px;
    color: var(--ink);
  }
  .swatch-value {
    font-family: var(--sans);
    font-size: 12px;
    color: var(--faint);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .prose {
    max-width: 720px;
    margin-top: clamp(40px, 6vw, 72px);
  }
  .prose :global(h2) {
    font-family: var(--serif);
    font-weight: 800;
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    letter-spacing: -0.01em;
    margin: 2em 0 0.5em;
  }
  .prose :global(p) {
    font-size: 18px;
    line-height: 1.7;
    color: var(--text);
    margin: 0 0 1.2em;
  }
  .prose :global(strong) {
    color: var(--ink);
    font-weight: 700;
  }
  .prose :global(blockquote) {
    margin: 1.6em 0;
    padding: 4px 0 4px 22px;
    border-left: 3px solid var(--brand-2);
    font-family: var(--serif);
    font-weight: 600;
    font-size: 1.3rem;
    line-height: 1.3;
    color: var(--ink);
  }
  .cs-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 13px;
    max-width: 720px;
    margin-top: clamp(40px, 6vw, 64px);
    padding-top: clamp(28px, 4vw, 40px);
    border-top: 1px solid var(--line);
  }

  @media (max-width: 720px) {
    .specimens {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
