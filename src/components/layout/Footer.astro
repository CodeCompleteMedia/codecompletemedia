---
import { SITE, NAV_LINKS, FOOTER_SERVICES, SOCIAL } from '../../consts';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="wrap">
    <div class="footer-grid">
      <div>
        <a class="brand-link" href="/" aria-label="Code Complete Media, home">
          <img src="/assets/logo-light.svg" alt="Code Complete Media" />
        </a>
        <p class="footer-tag">
          Agency quality, freelancer price, zero runaround. More than just a vibe.
        </p>
      </div>
      <div>
        <h4>Pages</h4>
        <div class="footer-col">
          {NAV_LINKS.map((l) => <a href={l.href}>{l.label}</a>)}
        </div>
      </div>
      <div>
        <h4>Services</h4>
        <div class="footer-col">
          {FOOTER_SERVICES.map((s) => <a href={s.href}>{s.label}</a>)}
        </div>
      </div>
      <div>
        <h4>Get in touch</h4>
        <div class="footer-col">
          <a href={SOCIAL.email}>{SITE.email}</a>
          <a href="/#contact">Start a project</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© {year} Code Complete Media. All rights reserved.</span>
      <span>Built with care, not just a template.</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--ink);
    color: var(--on-ink);
    padding-block: clamp(48px, 6vw, 64px) 32px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 32px;
  }
  .footer img {
    height: 46px;
    width: auto;
    margin-bottom: 16px;
  }
  .footer-tag {
    font-size: 15px;
    line-height: 1.55;
    color: var(--on-ink-muted);
    max-width: 30ch;
    margin: 0;
  }
  .footer h4 {
    font-family: var(--sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--on-ink-faint);
    margin: 0 0 14px;
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-col a {
    font-size: 15px;
    color: var(--on-ink-muted);
    text-decoration: none;
    cursor: pointer;
    transition: color 0.18s;
    width: fit-content;
  }
  .footer-col a:hover {
    color: var(--on-ink);
  }
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 46px;
    padding-top: 24px;
    border-top: 1px solid var(--ink-line);
    font-size: 14px;
    color: var(--on-ink-faint);
  }
  @media (max-width: 980px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
