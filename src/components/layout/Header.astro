---
import { NAV_LINKS } from '../../consts';

const pathname = Astro.url.pathname;
// Anchor links (/#section) get their active state from the scrollspy.
// Route links (e.g. /blog) need it resolved here from the current path.
const isCurrentRoute = (href: string) => {
  if (href.startsWith('/#') || href === '/') return false;
  return pathname === href || pathname.startsWith(href + '/');
};
---

<nav class="nav" id="nav" aria-label="Primary">
  <div class="wrap">
    <a class="brand-link" href="/" aria-label="Code Complete Media, home">
      <img src="/assets/logo.svg" alt="Code Complete Media" />
    </a>
    <div class="nav-links">
      {
        NAV_LINKS.map((l) => (
          <a href={l.href} aria-current={isCurrentRoute(l.href) ? 'page' : undefined}>
            {l.label}
          </a>
        ))
      }
      <a class="btn btn-ink" href="/#contact">Start a project</a>
    </div>
    <button
      class="menu-btn"
      id="menuBtn"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobileMenu"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
    </button>
  </div>
</nav>
<div class="mobile-menu" id="mobileMenu">
  {
    NAV_LINKS.map((l) => (
      <a href={l.href} aria-current={isCurrentRoute(l.href) ? 'page' : undefined}>
        {l.label}
      </a>
    ))
  }
</div>

<style>
  .nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    height: 72px;
    display: flex;
    align-items: center;
    background: oklch(0.98 0.006 286 / 0.78);
    backdrop-filter: saturate(160%) blur(14px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.25s, box-shadow 0.25s;
  }
  .nav.scrolled {
    border-bottom-color: var(--line);
    box-shadow: 0 1px 0 oklch(0.24 0.06 288 / 0.02);
  }
  .nav :global(.wrap) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    width: 100%;
  }
  .brand-link {
    display: flex;
    align-items: center;
    text-decoration: none;
  }
  .brand-link img {
    height: 38px;
    width: auto;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .nav-links a {
    cursor: pointer;
    padding: 9px 14px;
    border-radius: var(--r-sm);
    font-size: 15px;
    font-weight: 600;
    color: var(--muted);
    text-decoration: none;
    transition: background 0.18s, color 0.18s;
  }
  .nav-links a:hover {
    background: var(--surface-2);
    color: var(--ink);
  }
  .nav-links a[aria-current='page'] {
    color: var(--ink);
  }
  .nav-links a[aria-current='page']::after {
    content: '';
    display: block;
    height: 2px;
    margin-top: 4px;
    border-radius: 2px;
    background: var(--accent);
  }
  .nav :global(.btn) {
    padding: 11px 18px;
    font-size: 15px;
  }
  /* "Start a project" CTA: pure white text until hovered.
     Must out-specify `.nav-links a { color: var(--muted) }`. */
  .nav-links a.btn-ink {
    color: #fff;
  }
  .nav-links a.btn-ink:hover {
    color: #fff; /* stay white */
    background: oklch(0.17 0.055 288); /* darker than --ink */
    transform: translateY(-2px); /* lift */
    box-shadow: 0 16px 30px -8px oklch(0.2 0.06 288 / 0.55); /* soft blurred shadow */
  }
  .menu-btn {
    display: none;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    background: var(--surface);
    border: 1px solid var(--line-2);
    border-radius: var(--r-sm);
    cursor: pointer;
    color: var(--ink);
  }
  .mobile-menu {
    display: none;
  }
  @media (max-width: 860px) {
    .nav-links {
      display: none;
    }
    .menu-btn {
      display: flex;
    }
    .mobile-menu {
      display: block;
      position: fixed;
      inset: 72px 0 auto 0;
      z-index: 99;
      background: oklch(0.98 0.006 286 / 0.97);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--line);
      padding: 14px var(--gutter);
      flex-direction: column;
      transform: translateY(-12px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.22s, transform 0.22s var(--ease);
    }
    .mobile-menu.open {
      opacity: 1;
      transform: none;
      pointer-events: auto;
      display: flex;
    }
    .mobile-menu a {
      padding: 14px 6px;
      font-size: 18px;
      font-weight: 600;
      color: var(--ink);
      text-decoration: none;
      border-bottom: 1px solid var(--line);
      cursor: pointer;
    }
    .mobile-menu a:last-child {
      border-bottom: none;
    }
  }
</style>
