---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const works = (await getCollection('case-studies')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<section class="section dark jump" id="work">
  <div class="wrap">
    <div class="work-head" data-reveal>
      <div class="section-head">
        <span class="eyebrow"><span class="bar"></span>Selected work</span>
        <h2 class="h2">Sites that do the selling for you.</h2>
      </div>
    </div>
    <div class="work-grid">
      {
        works.map((w) => {
          return (
            <a class={`work-card${w.data.featured ? ' feat' : ''}`} href={`/work/${w.slug}`}>
              <div class="shot">
                <div class="shot-chrome">
                  <i /><i /><i /><span class="url">{w.data.result}</span>
                </div>
                <span class="shot-name">{w.data.client}</span>
                {w.data.image && (
                  <Image
                    class="shot-img"
                    src={w.data.image}
                    alt={w.data.imageAlt ?? `${w.data.client} website`}
                    widths={[400, 600, 1200]}
                    sizes="(min-width: 861px) 600px, 100vw"
                    loading="lazy"
                  />
                )}
              </div>
              <div class="work-body">
                <div class="work-result">{w.data.result}</div>
                <h3 class="work-title">{w.data.title}</h3>
                <div class="work-tags">
                  {w.data.tags.map((t) => (
                    <span class="chip">{t}</span>
                  ))}
                </div>
              </div>
            </a>
          );
        })
      }
    </div>
    <div class="more-row" data-reveal>
      <a class="more-link" href="/work">
        More work
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .work-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }
  .work-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    margin-top: clamp(34px, 5vw, 48px);
  }
  .work-grid :global(.feat) {
    grid-column: 1 / -1;
  }
  .work-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: var(--r-lg);
    overflow: hidden;
    background: var(--ink-panel);
    border: 1px solid var(--ink-line);
    transition: transform 0.28s var(--ease), border-color 0.28s;
  }
  .work-card:hover {
    transform: translateY(-5px);
    border-color: var(--brand-2);
  }
  .shot {
    position: relative;
    aspect-ratio: 16/10;
    background: linear-gradient(135deg, oklch(0.29 0.05 288), oklch(0.26 0.055 290));
    overflow: hidden;
  }
  .feat .shot {
    aspect-ratio: 21/8;
  }
  .shot::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(120% 80% at 80% -10%, oklch(0.72 0.06 272 / 0.28), transparent 55%);
  }
  .shot-chrome {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 38px;
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 0 14px;
    background: oklch(0.24 0.055 288 / 0.55);
    border-bottom: 1px solid var(--ink-line);
    z-index: 2;
  }
  .shot-chrome i {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--ink-line);
  }
  .shot-chrome .url {
    margin-left: 8px;
    font-family: var(--sans);
    font-size: 11.5px;
    color: var(--on-ink-faint);
  }
  .shot-name {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--serif);
    font-weight: 800;
    font-size: clamp(28px, 4vw, 52px);
    color: oklch(1 0 0 / 0.9);
    z-index: 0;
    letter-spacing: -0.01em;
  }
  .shot-img {
    position: absolute;
    top: 38px; /* sits below the browser chrome bar */
    left: 0;
    width: 100%; /* override intrinsic width/height attrs from <Image> */
    height: calc(100% - 38px);
    object-fit: cover;
    object-position: top center; /* top aligned */
    z-index: 1;
  }
  .work-body {
    padding: 22px 24px 26px;
  }
  .work-result {
    font-family: var(--sans);
    font-size: 12.5px;
    color: var(--brand-2);
    margin-bottom: 9px;
  }
  .work-title {
    font-family: var(--serif);
    font-weight: 700;
    font-size: clamp(1.25rem, 1.8vw, 1.6rem);
    line-height: 1.12;
    margin: 0 0 14px;
    color: var(--on-ink);
  }
  .work-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
  }
  .more-row {
    display: flex;
    justify-content: center;
    margin-top: clamp(28px, 4vw, 40px);
  }
  .more-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--sans);
    font-weight: 700;
    font-size: 16px;
    color: var(--brand-2);
    text-decoration: none;
    padding: 10px 4px;
  }
  .more-link svg {
    transition: transform 0.3s var(--ease);
  }
  .more-link:hover svg {
    transform: translateX(5px);
  }
  @media (max-width: 860px) {
    .work-grid {
      grid-template-columns: 1fr;
    }
    .work-grid :global(.feat) {
      grid-column: auto;
    }
    .feat .shot {
      aspect-ratio: 16/10;
    }
  }
</style>
