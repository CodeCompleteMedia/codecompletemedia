---
import { Image } from 'astro:assets';
import portrait from '../../assets/matthew-higley.jpeg';

const values = [
  {
    t: 'Sweat the details',
    d: 'The small stuff is the work. I spend real time on the things a lot of people skip, because that is what you feel once the site is live.',
  },
  {
    t: 'One point of contact',
    d: 'You talk to the person doing the work, which is me. Nothing gets garbled passing through an account manager first.',
  },
  {
    t: 'Own everything',
    d: 'Your code, content, and accounts stay yours. I build things so you could pick them up and run them without me if you ever wanted to.',
  },
];
---

<section class="section wrap jump" id="about">
  <div class="section-head" data-reveal>
    <span class="eyebrow"><span class="bar"></span>About</span>
    <h2 class="h2">Three things I never cut.</h2>
    <p class="lead" style="max-width:54ch">
      CodeCompleteMedia is one person, and that person is me. I handle the design, the code, and the
      words, and you deal with me directly from the first call to launch.
    </p>
  </div>
  <div class="values">
    {
      values.map((v) => (
        <div class="value" data-reveal>
          <h3>{v.t}</h3>
          <p>{v.d}</p>
        </div>
      ))
    }
  </div>
  <div class="founder" data-reveal style="margin-top:clamp(34px,5vw,52px)">
    <Image
      class="portrait"
      src={portrait}
      alt="Matthew Higley, founder of CodeCompleteMedia"
      widths={[240, 480, 800]}
      sizes="(max-width: 860px) 240px, 400px"
      loading="lazy"
    />
    <div>
      <h3>Matthew Higley</h3>
      <div class="role">Founder &amp; Lead</div>
      <p>
        I'm a designer and developer, and I've been building websites for a while now. When you hire
        me, you get me on the work from start to finish, not a junior or a rotating team you never
        actually meet.
      </p>
    </div>
  </div>
</section>

<style>
  .values {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(20px, 3vw, 40px);
    margin-top: clamp(30px, 4vw, 46px);
    counter-reset: val;
  }
  .value {
    position: relative;
    padding-top: 24px;
    border-top: 2px solid var(--ink);
  }
  .value::before {
    counter-increment: val;
    content: '0' counter(val);
    font-family: var(--sans);
    font-size: 13px;
    color: var(--accent-cta);
    position: absolute;
    top: 24px;
    right: 0;
  }
  .value h3 {
    font-family: var(--serif);
    font-weight: 700;
    font-size: 1.45rem;
    margin: 0 0 8px;
  }
  .value p {
    font-size: 15.5px;
    color: var(--muted);
    margin: 0;
  }
  .founder {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: clamp(24px, 4vw, 48px);
    align-items: center;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-xl);
    padding: clamp(24px, 3.4vw, 44px);
    margin-top: clamp(30px, 4vw, 46px);
  }
  .portrait {
    width: 100%;
    height: auto; /* let aspect-ratio govern; override <Image> height attr */
    aspect-ratio: 1;
    object-fit: cover;
    object-position: center top;
    border-radius: var(--r-lg);
    background: linear-gradient(140deg, oklch(0.72 0.06 272 / 0.3), var(--surface-3));
  }
  .founder h3 {
    font-family: var(--serif);
    font-weight: 800;
    font-size: clamp(1.7rem, 3vw, 2.5rem);
    margin: 0;
    letter-spacing: -0.01em;
  }
  .founder .role {
    font-family: var(--sans);
    font-size: 14px;
    color: var(--accent-cta);
    margin: 8px 0 16px;
  }
  .founder p {
    font-size: 18px;
    line-height: 1.6;
    color: var(--text);
    margin: 0;
    max-width: 46ch;
  }
  @media (max-width: 980px) {
    .values {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 860px) {
    .founder {
      grid-template-columns: 1fr;
      text-align: left;
    }
    .portrait {
      max-width: 240px;
    }
  }
</style>
