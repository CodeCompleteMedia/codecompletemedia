---
const stats = [
  { n: 1, suffix: '', s: 'person, start to finish' },
  { n: 0, suffix: '', s: 'mystery invoices' },
  { n: 48, suffix: 'hr', s: 'to project kickoff' },
  { n: 100, suffix: '%', s: 'yours to keep' },
];
---

<section class="section wrap">
  <div class="section-head" data-reveal style="max-width:46ch">
    <span class="eyebrow"><span class="bar"></span>The offer, in numbers</span>
    <h2 class="h2">Less overhead. More of what matters.</h2>
  </div>
  <div class="stat-band">
    {
      stats.map((st) => (
        <div class="stat" data-reveal>
          <div class="n" data-count={st.n} data-suffix={st.suffix}>
            0{st.suffix}
          </div>
          <div class="s">{st.s}</div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .stat-band {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    margin-top: clamp(34px, 5vw, 52px);
    border-block: 1px solid var(--line);
  }
  .stat {
    padding: clamp(26px, 3.4vw, 40px) clamp(16px, 2vw, 28px);
    border-left: 1px solid var(--line);
  }
  .stat:first-child {
    border-left: none;
    padding-left: 0;
  }
  .stat .n {
    font-family: var(--serif);
    font-weight: 800;
    font-size: clamp(2.6rem, 5vw, 4.2rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--brand);
  }
  .stat .s {
    font-size: 15px;
    color: var(--muted);
    margin-top: 8px;
    max-width: 18ch;
  }
  @media (max-width: 980px) {
    .stat-band {
      grid-template-columns: repeat(2, 1fr);
    }
    .stat {
      border-left: 1px solid var(--line);
    }
    .stat:nth-child(odd) {
      border-left: none;
      padding-left: 0;
    }
    .stat:nth-child(3),
    .stat:nth-child(4) {
      border-top: 1px solid var(--line);
    }
  }
  @media (max-width: 560px) {
    .stat-band {
      grid-template-columns: 1fr;
    }
    .stat {
      border-left: none;
      padding-left: 0;
      border-top: 1px solid var(--line);
    }
    .stat:first-child {
      border-top: none;
    }
  }
</style>
