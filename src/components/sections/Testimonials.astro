---
// TODO(matt): replace these three placeholders with real client quotes and names.
// Slots are held per your call; nothing here is a real testimonial yet.
const testimonials = [
  {
    q: 'Real client quote goes here.',
    n: 'Client Name',
    r: 'Role, Company',
  },
  {
    q: 'Real client quote goes here.',
    n: 'Client Name',
    r: 'Role, Company',
  },
  {
    q: 'Real client quote goes here.',
    n: 'Client Name',
    r: 'Role, Company',
  },
];
---

<section class="section wrap">
  <div class="section-head" data-reveal>
    <span class="eyebrow"><span class="bar"></span>In their words</span>
    <h2 class="h2">The kind of feedback I build for.</h2>
  </div>
  <div class="quotes">
    {
      testimonials.map((t, i) => (
        <div class={`quote${i === 0 ? ' lead-quote' : ''}`} data-reveal>
          <div class="mark">&ldquo;</div>
          <q>{t.q}</q>
          <div class="who">
            <span class="avatar"></span>
            <div>
              <div class="nm">{t.n}</div>
              <div class="rl">{t.r}</div>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .quotes {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 18px;
    margin-top: clamp(30px, 4vw, 44px);
  }
  .quote {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    padding: clamp(24px, 3vw, 34px);
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .quote.lead-quote {
    grid-row: span 2;
    justify-content: space-between;
  }
  .quote .mark {
    font-family: var(--serif);
    font-weight: 800;
    font-size: 54px;
    line-height: 0.4;
    height: 24px;
    color: var(--brand-2);
  }
  .quote.lead-quote .mark {
    font-size: 80px;
    height: 40px;
  }
  .quote q {
    quotes: none;
    font-size: 17px;
    line-height: 1.5;
    color: var(--text);
    font-weight: 500;
  }
  .quote.lead-quote q {
    font-family: var(--serif);
    font-weight: 600;
    font-size: clamp(1.4rem, 2.4vw, 2rem);
    line-height: 1.22;
    letter-spacing: -0.01em;
  }
  .quote q::before,
  .quote q::after {
    content: '';
  }
  .who {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--brand), var(--brand-2));
    flex: none;
  }
  .who .nm {
    font-weight: 700;
    font-size: 15px;
  }
  .who .rl {
    font-size: 13px;
    color: var(--faint);
  }
  @media (max-width: 860px) {
    .quotes {
      grid-template-columns: 1fr;
    }
    .quote.lead-quote {
      grid-row: auto;
    }
  }
</style>
