---
const steps = [
  { n: '01', t: 'Plan', d: 'We dig into your goals, your customers, and what success actually looks like.' },
  { n: '02', t: 'Design', d: 'You see real, interactive design early and often. No surprises at the end.' },
  { n: '03', t: 'Build', d: 'Clean, fast, accessible code on a stack that will not box you in.' },
  { n: '04', t: 'Grow', d: 'Launch is the start. We measure, tune, and keep things moving.' },
];
---

<section class="section wrap">
  <div class="section-head" data-reveal>
    <span class="eyebrow"><span class="bar"></span>How we work</span>
    <h2 class="h2">Four steps. No black box.</h2>
  </div>
  <div class="steps">
    {
      steps.map((p) => (
        <div class="step" data-reveal>
          <div class="n">{p.n}</div>
          <div class="rule"></div>
          <h3>{p.t}</h3>
          <p>{p.d}</p>
        </div>
      ))
    }
  </div>
</section>

<style>
  .steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(18px, 2.5vw, 28px);
    margin-top: clamp(34px, 5vw, 48px);
  }
  .step {
    position: relative;
  }
  .step .n {
    font-family: var(--serif);
    font-weight: 800;
    font-size: 44px;
    line-height: 1;
    color: var(--line-2);
  }
  .step .rule {
    height: 3px;
    width: 38px;
    background: var(--accent);
    border-radius: 2px;
    margin: 14px 0 16px;
  }
  .step h3 {
    font-family: var(--serif);
    font-weight: 700;
    font-size: 1.35rem;
    margin: 0;
  }
  .step p {
    font-size: 15px;
    color: var(--muted);
    margin: 8px 0 0;
  }
  @media (max-width: 980px) {
    .steps {
      grid-template-columns: repeat(2, 1fr);
      row-gap: 34px;
    }
  }
  @media (max-width: 560px) {
    .steps {
      grid-template-columns: 1fr;
    }
  }
</style>
