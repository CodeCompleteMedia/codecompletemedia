---
import { SITE } from '../../consts';

const faqs = [
  {
    q: 'What does a project cost?',
    a: 'It depends on the scope, but I quote flat and up front so the invoice never surprises you.',
  },
  {
    q: 'How long does a site take?',
    a: 'Most marketing sites take four to eight weeks from kickoff. You will have the timeline before I start.',
  },
  {
    q: 'Do I own everything at the end?',
    a: 'Yes. The code, content, and accounts are all yours. I hand everything over clean when we are done.',
  },
  {
    q: 'Do you really use AI?',
    a: 'Yes, and I am upfront about it. It helps me move faster, but I make every real decision myself.',
  },
];
---

<section class="section wrap jump" id="contact">
  <div class="contact-grid">
    <div>
      <span class="eyebrow"><span class="bar"></span>Contact</span>
      <h2 class="h2" style="margin-top:12px">Let's build something.</h2>
      <p class="lead" style="margin-top:18px; max-width:42ch">
        Tell me what you are working on. You will hear back from me, usually within one business day.
      </p>
      <div class="contact-info">
        <div>
          <div class="info-k">Email</div>
          <a class="info-v" href={`mailto:${SITE.email}`}>{SITE.email}</a>
        </div>
        <div>
          <div class="info-k">Response time</div>
          <div class="info-v">{SITE.responseTime}</div>
        </div>
      </div>
      <div class="faq">
        {
          faqs.map((f, i) => (
            <div class="faq-item" data-open="false">
              <button class="faq-head" aria-expanded="false" aria-controls={`faq-p-${i}`}>
                {f.q}
                <span class="pm" aria-hidden="true">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
                    <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" />
                  </svg>
                </span>
              </button>
              <div class="faq-panel" id={`faq-p-${i}`}>
                <div>
                  <p>{f.a}</p>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="form-card">
      <form id="contactForm" action="/api/contact" method="POST" novalidate>
        <div class="field">
          <label for="f-name">Name <span class="req">*</span></label>
          <input type="text" id="f-name" name="name" autocomplete="name" required aria-describedby="e-name" />
          <span class="err" id="e-name">Please enter your name.</span>
        </div>
        <div class="field">
          <label for="f-email">Email <span class="req">*</span></label>
          <input type="email" id="f-email" name="email" autocomplete="email" placeholder="you@company.com" required aria-describedby="e-email" />
          <span class="err" id="e-email">Please enter a valid email address.</span>
        </div>
        <div class="field">
          <label for="f-need">What do you need?</label>
          <select id="f-need" name="need">
            <option>A new website</option>
            <option>A redesign</option>
            <option>SEO &amp; marketing</option>
            <option>Copywriting</option>
            <option>Strategy &amp; advice</option>
            <option>Not sure yet</option>
          </select>
        </div>
        <div class="field">
          <label for="f-budget">Ballpark budget</label>
          <select id="f-budget" name="budget">
            <option>Under $5k</option>
            <option>$5k - $15k</option>
            <option>$15k - $40k</option>
            <option>$40k+</option>
            <option>Let's talk</option>
          </select>
        </div>
        <div class="field">
          <label for="f-msg">Tell me about it <span class="req">*</span></label>
          <textarea id="f-msg" name="message" placeholder="What are you building, and what does success look like?" required aria-describedby="e-msg"></textarea>
          <span class="err" id="e-msg">Tell us a little about the project.</span>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center">Send it over</button>
        <p class="form-note">No spam and no sales sequence, just a real reply from me.</p>
        <p class="form-error" id="formError" role="alert" hidden>
          Something went wrong sending your message. Please email me directly at
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
        </p>
      </form>
      <div class="form-success" id="formSuccess" hidden>
        <div class="tick-lg">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12.5 10 17.5 19 7" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
        <h3>Got it. Thank you.</h3>
        <p>I will get back to you within one business day. Talk soon.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(32px, 5vw, 68px);
    align-items: start;
  }
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 22px;
    margin-top: 32px;
  }
  .info-k {
    font-family: var(--sans);
    font-size: 13px;
    color: var(--faint);
    margin-bottom: 6px;
  }
  .info-v {
    font-family: var(--serif);
    font-weight: 700;
    font-size: 1.35rem;
    color: var(--ink);
    text-decoration: none;
  }
  a.info-v:hover {
    color: var(--accent-cta);
  }
  .faq {
    margin-top: 34px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .faq-item {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-md);
    overflow: hidden;
  }
  .faq-head {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    padding: 17px 18px;
    color: inherit;
    font-weight: 700;
    font-size: 15.5px;
  }
  .faq-head .pm {
    flex: none;
    color: var(--brand);
    transition: transform 0.3s var(--ease);
  }
  .faq-item[data-open='true'] .faq-head .pm {
    transform: rotate(45deg);
  }
  .faq-panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s var(--ease);
  }
  .faq-item[data-open='true'] .faq-panel {
    grid-template-rows: 1fr;
  }
  .faq-panel > div {
    overflow: hidden;
  }
  .faq-panel p {
    margin: 0;
    padding: 0 18px 17px;
    font-size: 14.5px;
    color: var(--muted);
    line-height: 1.55;
  }
  .form-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-xl);
    padding: clamp(24px, 3vw, 38px);
    box-shadow: var(--shadow-md);
  }
  .field {
    margin-bottom: 16px;
  }
  .field label {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 7px;
  }
  .field .req {
    color: var(--accent-cta);
  }
  .field input,
  .field select,
  .field textarea {
    width: 100%;
    padding: 13px 15px;
    border: 1px solid var(--line-2);
    border-radius: var(--r-md);
    font-size: 15px;
    font-family: inherit;
    color: var(--ink);
    background: var(--bg);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .field textarea {
    resize: vertical;
    min-height: 108px;
  }
  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    border-color: var(--brand);
    box-shadow: 0 0 0 3px oklch(0.37 0.075 287 / 0.14);
  }
  .field [aria-invalid='true'] {
    border-color: var(--accent-cta);
    box-shadow: 0 0 0 3px oklch(0.575 0.185 25 / 0.14);
  }
  .field .err {
    display: none;
    font-size: 13px;
    color: var(--accent-cta);
    margin-top: 6px;
    font-weight: 600;
  }
  .field.invalid .err {
    display: block;
  }
  .form-error {
    font-size: 13.5px;
    color: var(--accent-cta);
    text-align: center;
    font-weight: 600;
    margin: 12px 0 0;
  }
  .form-error a {
    color: var(--accent-cta);
    text-underline-offset: 2px;
  }
  .form-note {
    font-size: 13px;
    color: var(--faint);
    text-align: center;
    margin: 4px 0 0;
  }
  .form-success {
    text-align: center;
    padding: 36px 12px;
  }
  .form-success .tick-lg {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--brand), var(--brand-2));
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
  }
  .form-success h3 {
    font-family: var(--serif);
    font-weight: 800;
    font-size: 1.8rem;
    margin: 0 0 10px;
  }
  .form-success p {
    font-size: 16px;
    color: var(--muted);
    max-width: 32ch;
    margin: 0 auto;
  }
  @media (max-width: 860px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
