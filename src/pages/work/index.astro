---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../consts';

const works = (await getCollection('case-studies')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title={`Work · ${SITE.shortName}`}
  description="Selected case studies — sites and brands we've designed, built, and grown."
>
  <section class="page-head wrap">
    <span class="eyebrow"><span class="bar"></span>Selected work</span>
    <h1 class="h1">Sites that do the selling for you.</h1>
    <p class="lead">A look at recent projects — the problem, what we did, and what changed.</p>
  </section>

  <section class="section wrap" style="padding-top:0">
    <div class="work-index-grid">
      {
        works.map((w) => (
          <a class="wcard" href={`/work/${w.slug}`}>
            <div class="shot">
              <div class="shot-chrome">
                <i /><i /><i /><span class="url">{w.data.result}</span>
              </div>
              <span class="shot-name">{w.data.client}</span>
              {w.data.image && (
                <Image
                  class="shot-img"
                  src={w.data.image}
                  alt={w.data.imageAlt ?? `${w.data.client} website`}
                  widths={[400, 800]}
                  sizes="(min-width: 861px) 50vw, 100vw"
                  loading="lazy"
                />
              )}
            </div>
            <div class="wcard-body">
              <div class="wcard-result">{w.data.result}</div>
              <h2>{w.data.title}</h2>
              <div class="wcard-tags">
                {w.data.tags.map((t) => (
                  <span class="chip">{t}</span>
                ))}
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .page-head {
    padding-top: clamp(128px, 16vw, 168px);
    padding-bottom: clamp(36px, 5vw, 56px);
  }
  .page-head .h1 {
    margin-top: 14px;
    font-size: clamp(2.6rem, 5.5vw, 4.6rem);
  }
  .page-head .lead {
    margin-top: 18px;
    max-width: 52ch;
  }
  .work-index-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
  }
  .wcard {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: var(--r-lg);
    overflow: hidden;
    background: var(--surface);
    border: 1px solid var(--line);
    transition: transform 0.28s var(--ease), box-shadow 0.28s;
  }
  .wcard:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
  }
  .shot {
    position: relative;
    aspect-ratio: 16/10;
    background: linear-gradient(135deg, oklch(0.29 0.05 288), oklch(0.26 0.055 290));
    overflow: hidden;
  }
  .shot::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(120% 80% at 80% -10%, oklch(0.72 0.06 272 / 0.28), transparent 55%);
  }
  .shot-chrome {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 38px;
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 0 14px;
    background: oklch(0.24 0.055 288 / 0.55);
    border-bottom: 1px solid var(--ink-line);
    z-index: 2;
  }
  .shot-chrome i {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--ink-line);
  }
  .shot-chrome .url {
    margin-left: 8px;
    font-family: var(--sans);
    font-size: 11.5px;
    color: var(--on-ink-faint);
  }
  .shot-name {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--serif);
    font-weight: 800;
    font-size: clamp(28px, 4vw, 52px);
    color: oklch(1 0 0 / 0.9);
    z-index: 0;
    letter-spacing: -0.01em;
  }
  .shot-img {
    position: absolute;
    top: 38px; /* sits below the browser chrome bar */
    left: 0;
    width: 100%; /* override intrinsic width/height attrs from <Image> */
    height: calc(100% - 38px);
    object-fit: cover;
    object-position: top center; /* top aligned */
    z-index: 1;
  }
  .wcard-body {
    padding: 22px 24px 26px;
  }
  .wcard-result {
    font-family: var(--sans);
    font-size: 12.5px;
    color: var(--accent-cta);
    margin-bottom: 9px;
  }
  .wcard h2 {
    font-family: var(--serif);
    font-weight: 700;
    font-size: clamp(1.25rem, 1.9vw, 1.6rem);
    line-height: 1.14;
    margin: 0 0 14px;
  }
  .wcard-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
  }
  @media (max-width: 860px) {
    .work-index-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
