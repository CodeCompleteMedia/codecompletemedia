# Copy to .env and fill in. Never commit real secrets.
# These back the contact form serverless function (src/pages/api/contact.ts).
# Set the same names in your Vercel project's Environment Variables for production.

# --- Email delivery (Resend) ---
# Create a key at https://resend.com → API Keys.
RESEND_API_KEY=
# Where contact-form notifications are sent (your inbox).
CONTACT_NOTIFY_TO=matt@codecompletemedia.com
# Verified sender. Use a verified domain address once your domain is set up in
# Resend, e.g. "CodeCompleteMedia <website@codecompletemedia.com>".
# For first tests you can use Resend's sandbox sender: "onboarding@resend.dev".
CONTACT_NOTIFY_FROM=CodeCompleteMedia <onboarding@resend.dev>

# --- Google Sheet (Apps Script web app) ---
# Deploy docs/google-sheet-apps-script.gs as a Web App and paste its /exec URL.
GOOGLE_SHEET_WEBHOOK_URL=
